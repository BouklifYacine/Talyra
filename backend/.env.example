# PostgreSQL connection string (Prisma + Better Auth)
DATABASE_URL="postgresql://username:password@localhost:5432/naryo"

# Port Nest listens on
PORT=3001

# Origin of the TanStack Start front-end (CORS + Better Auth trustedOrigins)
FRONTEND_URL=http://localhost:3000

# Base URL of this API, used by Better Auth for callback/cookie generation
BETTER_AUTH_URL=http://localhost:3001

# Generate with: bunx @better-auth/cli secret
BETTER_AUTH_SECRET=
