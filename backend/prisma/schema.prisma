generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// Better Auth tables. Keep these compatible with Better Auth.
model User {
  id            String       @id
  name          String
  email         String
  emailVerified Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  memberships   Membership[]
  payments      Payment[]    @relation("PaymentRecordedBy")
  activityLogs  ActivityLog[] @relation("ActivityActor")

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String   @id
  accountId             String
  providerId            String
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// Tenant is the root of every business record.
model Tenant {
  id           String       @id @default(cuid())
  name         String
  businessType BusinessType @map("business_type")
  email        String?
  logoUrl      String?
  legalName    String?
  vatMode      VatMode      @default(EXEMPT)
  plan        TenantPlan   @default(TRIAL)
  status      TenantStatus @default(ACTIVE)
  currency    String       @default("EUR")
  timeZone    String       @default("Europe/Paris")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  memberships Membership[]
  contacts    Contact[]
  leads       Lead[]
  resources   CalendarResource[]
  prestations Prestation[]
  slots       BookingSlot[]
  optionHolds OptionHold[]
  catalog     CatalogItem[]
  quotes      Quote[]
  quoteLines  QuoteLine[]
  contracts   Contract[]
  signatures  SignatureProof[]
  schedules   PaymentSchedule[]
  installments PaymentInstallment[]
  payments    Payment[]
  invoices    Invoice[]
  portalTokens PortalToken[]
  activityLogs ActivityLog[]
  outboxEvents OutboxEvent[]

  @@map("tenant")
}

// A user can work for more than one tenant. The first membership is OWNER.
model Membership {
  id        String         @id @default(cuid())
  tenantId  String         @map("tenant_id")
  userId    String         @map("user_id")
  role      MembershipRole @default(OWNER)
  createdAt DateTime       @default(now())
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@index([userId])
  @@map("membership")
}

model Contact {
  id               String       @id @default(cuid())
  tenantId         String       @map("tenant_id")
  firstName        String?
  lastName         String?
  email            String?
  phone            String?
  marketingConsent Boolean      @default(false) @map("marketing_consent")
  notes            String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  leads            Lead[]
  prestations      Prestation[]

  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@map("contact")
}

model Lead {
  id             String    @id @default(cuid())
  tenantId       String    @map("tenant_id")
  contactId      String?   @map("contact_id")
  source         String?
  stage          LeadStage @default(NEW)
  lastActivityAt DateTime? @map("last_activity_at")
  lostReason     String?   @map("lost_reason")
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact        Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)

  @@index([tenantId, stage])
  @@index([contactId])
  @@map("lead")
}

model CalendarResource {
  id        String        @id @default(cuid())
  tenantId  String        @map("tenant_id")
  name      String
  active    Boolean       @default(true)
  createdAt DateTime      @default(now())
  tenant    Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  slots     BookingSlot[]

  @@unique([tenantId, name])
  @@map("calendar_resource")
}

model Prestation {
  id          String            @id @default(cuid())
  tenantId    String            @map("tenant_id")
  contactId   String            @map("contact_id")
  title       String
  eventType   String?           @map("event_type")
  status      PrestationStatus  @default(DRAFT)
  amountCents Int               @default(0) @map("amount_cents")
  currency    String            @default("EUR")
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contact     Contact           @relation(fields: [contactId], references: [id], onDelete: Restrict)
  slots       BookingSlot[]
  quotes      Quote[]
  contracts   Contract[]
  schedules   PaymentSchedule[]
  payments    Payment[]
  invoices    Invoice[]
  portalTokens PortalToken[]

  @@index([tenantId, status])
  @@index([contactId])
  @@map("prestation")
}

model BookingSlot {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  prestationId  String        @map("prestation_id")
  resourceId    String        @map("resource_id")
  startsAt      DateTime      @map("starts_at") @db.Timestamptz(6)
  endsAt        DateTime      @map("ends_at") @db.Timestamptz(6)
  status        BookingStatus @default(OPTION)
  locationName  String?       @map("location_name")
  locationAddress String?     @map("location_address")
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation    Prestation    @relation(fields: [prestationId], references: [id], onDelete: Cascade)
  resource      CalendarResource @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  optionHold    OptionHold?

  @@index([tenantId, resourceId, startsAt])
  @@index([prestationId])
  @@map("booking_slot")
}

model OptionHold {
  id            String           @id @default(cuid())
  tenantId      String           @map("tenant_id")
  bookingSlotId String           @unique @map("booking_slot_id")
  status        OptionHoldStatus @default(ACTIVE)
  expiresAt     DateTime         @map("expires_at") @db.Timestamptz(6)
  createdAt     DateTime         @default(now())
  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  bookingSlot   BookingSlot      @relation(fields: [bookingSlotId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, expiresAt])
  @@map("option_hold")
}

model CatalogItem {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  label       String
  description String?
  unit        String   @default("unit")
  priceCents  Int      @map("price_cents")
  taxRateBps  Int      @default(0) @map("tax_rate_bps")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, active])
  @@map("catalog_item")
}

model Quote {
  id            String      @id @default(cuid())
  tenantId      String      @map("tenant_id")
  prestationId  String      @map("prestation_id")
  number        Int
  version       Int         @default(1)
  status        QuoteStatus @default(DRAFT)
  validUntil    DateTime?   @map("valid_until")
  subtotalCents Int         @map("subtotal_cents")
  taxCents      Int         @map("tax_cents")
  totalCents    Int         @map("total_cents")
  currency      String      @default("EUR")
  sentAt        DateTime?   @map("sent_at")
  immutableAt   DateTime?   @map("immutable_at")
  pdfHash       String?     @map("pdf_hash")
  storageKey    String?     @map("storage_key")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation    Prestation  @relation(fields: [prestationId], references: [id], onDelete: Restrict)
  lines         QuoteLine[]
  contract      Contract?

  @@unique([tenantId, number, version])
  @@index([prestationId])
  @@map("quote")
}

model QuoteLine {
  id             String   @id @default(cuid())
  tenantId       String   @map("tenant_id")
  quoteId        String   @map("quote_id")
  label          String
  description    String?
  quantity       Decimal  @default(1) @db.Decimal(12, 3)
  unitPriceCents Int      @map("unit_price_cents")
  taxRateBps     Int      @default(0) @map("tax_rate_bps")
  totalCents     Int      @map("total_cents")
  position       Int
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote          Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@unique([quoteId, position])
  @@index([tenantId])
  @@map("quote_line")
}

model Contract {
  id            String         @id @default(cuid())
  tenantId      String         @map("tenant_id")
  prestationId  String         @map("prestation_id")
  quoteId       String         @unique @map("quote_id")
  status        ContractStatus @default(DRAFT)
  documentHash  String?        @map("document_hash")
  storageKey    String?        @map("storage_key")
  sentAt        DateTime?      @map("sent_at")
  signedAt      DateTime?      @map("signed_at")
  immutableAt   DateTime?      @map("immutable_at")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation    Prestation     @relation(fields: [prestationId], references: [id], onDelete: Restrict)
  quote         Quote          @relation(fields: [quoteId], references: [id], onDelete: Restrict)
  signatures    SignatureProof[]

  @@index([tenantId, status])
  @@map("contract")
}

model SignatureProof {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  contractId  String   @map("contract_id")
  signerEmail String   @map("signer_email")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  documentHash String  @map("document_hash")
  signedAt    DateTime @default(now()) @map("signed_at")
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contract    Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([tenantId, signedAt])
  @@map("signature_proof")
}

model PaymentSchedule {
  id           String                @id @default(cuid())
  tenantId     String                @map("tenant_id")
  prestationId String                @map("prestation_id")
  status       PaymentScheduleStatus @default(DRAFT)
  activatedAt  DateTime?             @map("activated_at")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  tenant       Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation   Prestation            @relation(fields: [prestationId], references: [id], onDelete: Restrict)
  installments PaymentInstallment[]

  @@index([tenantId, status])
  @@map("payment_schedule")
}

model PaymentInstallment {
  id         String            @id @default(cuid())
  tenantId   String            @map("tenant_id")
  scheduleId String            @map("schedule_id")
  sequence   Int
  amountCents Int               @map("amount_cents")
  dueAt      DateTime          @map("due_at") @db.Timestamptz(6)
  status     InstallmentStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  tenant     Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedule   PaymentSchedule   @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  payments   Payment[]

  @@unique([scheduleId, sequence])
  @@index([tenantId, status, dueAt])
  @@map("payment_installment")
}

model Payment {
  id            String               @id @default(cuid())
  tenantId      String               @map("tenant_id")
  prestationId  String               @map("prestation_id")
  installmentId String?              @map("installment_id")
  recordedById  String               @map("recorded_by_id")
  method        OfflinePaymentMethod
  amountCents   Int                  @map("amount_cents")
  receivedAt    DateTime             @map("received_at") @db.Timestamptz(6)
  reference     String?
  receiptKey    String?              @map("receipt_key")
  createdAt     DateTime             @default(now())
  tenant        Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation    Prestation           @relation(fields: [prestationId], references: [id], onDelete: Restrict)
  installment   PaymentInstallment?  @relation(fields: [installmentId], references: [id], onDelete: SetNull)
  recordedBy    User                 @relation("PaymentRecordedBy", fields: [recordedById], references: [id], onDelete: Restrict)

  @@index([tenantId, receivedAt])
  @@index([installmentId])
  @@map("payment")
}

model Invoice {
  id            String        @id @default(cuid())
  tenantId      String        @map("tenant_id")
  prestationId  String        @map("prestation_id")
  number        Int
  type          InvoiceType
  status        InvoiceStatus @default(DRAFT)
  subtotalCents Int           @map("subtotal_cents")
  taxCents      Int           @map("tax_cents")
  totalCents    Int           @map("total_cents")
  currency      String        @default("EUR")
  issuedAt      DateTime?     @map("issued_at")
  immutableAt   DateTime?     @map("immutable_at")
  pdfHash       String?       @map("pdf_hash")
  storageKey    String?       @map("storage_key")
  createdAt     DateTime      @default(now())
  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation    Prestation    @relation(fields: [prestationId], references: [id], onDelete: Restrict)

  @@unique([tenantId, number])
  @@index([prestationId])
  @@map("invoice")
}

model PortalToken {
  id           String      @id @default(cuid())
  tenantId     String      @map("tenant_id")
  prestationId String      @map("prestation_id")
  tokenHash    String      @unique @map("token_hash")
  scope        PortalScope @default(VIEW_DOSSIER)
  expiresAt    DateTime    @map("expires_at") @db.Timestamptz(6)
  revokedAt    DateTime?   @map("revoked_at")
  createdAt    DateTime    @default(now())
  tenant       Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  prestation   Prestation  @relation(fields: [prestationId], references: [id], onDelete: Cascade)

  @@index([tenantId, prestationId])
  @@map("portal_token")
}

model ActivityLog {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  actorId    String?  @map("actor_id")
  type       String
  targetType String   @map("target_type")
  targetId   String   @map("target_id")
  metadata   Json?
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  actor      User?    @relation("ActivityActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([targetType, targetId])
  @@map("activity_log")
}

model OutboxEvent {
  id         String      @id @default(cuid())
  tenantId   String      @map("tenant_id")
  type       String
  payload    Json
  status     OutboxStatus @default(PENDING)
  retryCount Int         @default(0) @map("retry_count")
  availableAt DateTime   @default(now()) @map("available_at")
  processedAt DateTime?  @map("processed_at")
  createdAt  DateTime    @default(now())
  tenant     Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, status, availableAt])
  @@map("outbox_event")
}

enum TenantPlan {
  TRIAL
  STARTER
  PRO
  STUDIO
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
}

enum VatMode {
  EXEMPT
  STANDARD
}

// The professional's trade. Drives templates and defaults down the line.
enum BusinessType {
  DECORATRICE
  NEGAFA
  WEDDING_PLANNER
  PHOTO_VIDEO
}

enum MembershipRole {
  OWNER
  MEMBER
}

enum LeadStage {
  NEW
  QUALIFIED
  PROPOSAL
  WON
  LOST
}

enum PrestationStatus {
  DRAFT
  OPTION
  CONFIRMED
  CANCELLED
  POSTPONED
}

enum BookingStatus {
  OPTION
  CONFIRMED
  CANCELLED
  POSTPONED
}

enum OptionHoldStatus {
  ACTIVE
  EXPIRED
  RELEASED
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  DECLINED
}

enum ContractStatus {
  DRAFT
  SENT
  SIGNED
  VOID
}

enum PaymentScheduleStatus {
  DRAFT
  ACTIVE
  COMPLETE
  OVERDUE
  CANCELLED
}

enum InstallmentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum OfflinePaymentMethod {
  BANK_TRANSFER
  CASH
  CHECK
}

enum InvoiceType {
  DEPOSIT
  BALANCE
  CREDIT_NOTE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  VOID
}

enum PortalScope {
  VIEW_DOSSIER
  SIGN_DOCUMENTS
}

enum OutboxStatus {
  PENDING
  PROCESSING
  SENT
  FAILED
  DEAD
}

